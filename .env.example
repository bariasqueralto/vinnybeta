# Landing page waitlist (pick one - all free)
# Option A: Google Sheets - paste your Apps Script Web app URL
VITE_GOOGLE_SHEETS_SCRIPT_URL=
# Option B: Web3Forms - emails to inbox
# VITE_WEB3FORMS_ACCESS_KEY=
# Option C: Formspree
# VITE_FORMSPREE_FORM_ID=

# Gmail (for syncing emails → network bubbles)
# 1. Go to https://console.cloud.google.com/
# 2. Create project → APIs & Services → Credentials → Create OAuth 2.0 Client ID
# 3. Application type: Web application
# 4. Authorized JavaScript origins: http://localhost:5173 (or your dev port)
# 5. Enable Gmail API in APIs & Services → Library
# 6. Copy "Client ID" below
VITE_GOOGLE_CLIENT_ID=

# Gemini (powers Vinny AI chat + contact enrichment)
# 1. Go to https://aistudio.google.com/apikey
# 2. Create an API key (free tier: 15 RPM, 1M tokens/day)
# 3. Paste below — without this, Vinny falls back to basic keyword matching
VITE_GEMINI_API_KEY=

# Outlook (optional)
# Azure Portal → App registrations → SPA platform, Mail.Read permission
VITE_AZURE_CLIENT_ID=
VITE_AZURE_TENANT_ID=common
